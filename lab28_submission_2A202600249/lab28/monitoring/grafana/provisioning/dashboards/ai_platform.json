{
  "title": "AI Platform Overview",
  "uid": "ai-platform-overview",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API Gateway - Total Requests",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(increase(http_requests_total{job=\"api-gateway\"}[15m]))",
        "legendFormat": "Total Requests"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API Gateway - Error Rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.05 },
            { "color": "red", "value": 0.1 }
          ]},
          "unit": "percentunit"
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(http_requests_total{job=\"api-gateway\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"api-gateway\"}[5m]))",
        "legendFormat": "Error Rate"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "API Gateway - Up",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }]
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "up{job=\"api-gateway\"}",
        "legendFormat": "Status"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Kafka - Up",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }]
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "up{job=\"kafka\"}",
        "legendFormat": "Status"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "API Request Rate (req/sec)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(http_requests_total{job=\"api-gateway\"}[1m])) by (handler)",
        "legendFormat": "{{handler}}"
      }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "API Latency P95 (seconds)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"api-gateway\"}[5m])) by (le, handler))",
        "legendFormat": "p95 {{handler}}"
      }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Status Codes Over Time",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(http_requests_total{job=\"api-gateway\"}[1m])) by (status_code)",
        "legendFormat": "HTTP {{status_code}}"
      }]
    }
  ]
}
